# WebSocket URL of the orchestrator the agent registers with.
ORCHESTRATOR_URL=ws://localhost:10001

# HTTP URL of the communicator (LLM gateway) used for tool-calling requests.
COMMUNICATOR_URL=http://localhost:10000

# Shared API key. Used both to authenticate to the communicator and to protect
# this agent's own REST API (Bearer / x-api-key). Set to a strong random value.
API_KEY=

# Model identifier passed to the communicator for tool-calling.
MODEL=sonnet

# Port for this agent's HTTP REST API and health endpoint.
HEALTH_PORT=10014

# Directory holding conversation history data (index.json + NDJSON transcripts).
# Relative paths are resolved from the process working directory.
CHAT_HISTORY_DIR=./data/chat-history
